# RAZD — Notion integration
# Skopiuj do .env i uzupełnij wartości. Nigdy nie commituj .env.

# Notion Integration Token (Internal Integration Secret)
# Pobierz z: https://www.notion.so/my-integrations
RAZD_NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID bazy danych Notion do której RAZD zapisuje aktywności
# (wypełniane automatycznie po utworzeniu DB lub ręcznie)
RAZD_NOTION_DB_ID=c436737fb15c4e54af2d54b0d04a06c4

# Interwał synchronizacji w minutach (domyślnie 15)
RAZD_NOTION_SYNC_INTERVAL_MIN=15

# Czy eksportować URL-e do Notion (domyślnie false — privacy first)
RAZD_NOTION_EXPORT_URLS=false
